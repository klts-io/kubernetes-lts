 		}
 		hostRefs = append(hostRefs, vmo.Summary.Runtime.Host.Reference())
 	}
diff --git a/staging/src/k8s.io/legacy-cloud-providers/vsphere/vsphere.go b/staging/src/k8s.io/legacy-cloud-providers/vsphere/vsphere.go
