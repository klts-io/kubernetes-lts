diff --git a/staging/src/k8s.io/legacy-cloud-providers/vsphere/vsphere_util.go b/staging/src/k8s.io/legacy-cloud-providers/vsphere/vsphere_util.go
index db4f361f024..09caa695ef1 100644
--- a/staging/src/k8s.io/legacy-cloud-providers/vsphere/vsphere_util.go
+++ b/staging/src/k8s.io/legacy-cloud-providers/vsphere/vsphere_util.go
@@ -139,7 +139,7 @@ func getSharedDatastoresInK8SCluster(ctx context.Context, nodeManager *NodeManag
 	if len(nodeVmDetails) == 0 {
 		msg := fmt.Sprintf("Kubernetes node nodeVmDetail details is empty. nodeVmDetails : %+v", nodeVmDetails)
 		klog.Error(msg)
-		return nil, fmt.Errorf(msg)
+		return nil, fmt.Errorf("%s", msg)
 	}
 	var sharedDatastores []*vclib.DatastoreInfo
 	for _, nodeVmDetail := range nodeVmDetails {
@@ -215,7 +215,7 @@ func getPbmCompatibleDatastore(ctx context.Context, vcClient *vim25.Client, stor
 	}
 	if len(sharedDs) == 0 {
 		msg := "No shared datastores found in the endpoint virtual center"
-		klog.Errorf(msg)
+		klog.Errorf("%s", msg)
 		return nil, errors.New(msg)
 	}
 	compatibleDatastores, _, err := pbmClient.GetCompatibleDatastores(ctx, storagePolicyID, sharedDs)
diff --git a/vendor/golang.org/x/tools/internal/tokeninternal/tokeninternal.go b/vendor/golang.org/x/tools/internal/tokeninternal/tokeninternal.go
index 7e638ec24fc..2144280efad 100644
--- a/vendor/golang.org/x/tools/internal/tokeninternal/tokeninternal.go
+++ b/vendor/golang.org/x/tools/internal/tokeninternal/tokeninternal.go
@@ -73,9 +73,18 @@ func AddExistingFiles(fset *token.FileSet, files []*token.File) {
 		_     *token.File // changed to atomic.Pointer[token.File] in go1.19
 	}
 
-	// If the size of token.FileSet changes, this will fail to compile.
-	const delta = int64(unsafe.Sizeof(tokenFileSet{})) - int64(unsafe.Sizeof(token.FileSet{}))
-	var _ [-delta * delta]int
+	// If token.FileSet layout changed (for example in go1.25), prefer using
+	// the standard-library API when available.
+	if unsafe.Sizeof(tokenFileSet{}) != unsafe.Sizeof(token.FileSet{}) {
+		type addExistingFiles interface {
+			AddExistingFiles(...*token.File)
+		}
+		if fs, ok := interface{}(fset).(addExistingFiles); ok {
+			fs.AddExistingFiles(files...)
+			return
+		}
+		panic("unexpected token.FileSet size")
+	}
 
 	type uP = unsafe.Pointer
 	var ptr *tokenFileSet
-- 
